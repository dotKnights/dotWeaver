DATABASE_URL="postgres://user:password@localhost:5432/dbname"
BETTER_AUTH_SECRET="min-32-character-random-secret"
BETTER_AUTH_URL="http://localhost:5173"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# DOT-16 runner (Phase 2)
# WORKSPACE_ROOT doit être bind-montable dans le conteneur. Sur un hôte Linux, /tmp convient.
# Sur Mac + Colima, le chemin DOIT être sous $HOME (Colima ne partage pas /tmp avec sa VM) :
#   WORKSPACE_ROOT="/Users/<you>/.dotweaver/workspaces"
WORKSPACE_ROOT="/tmp/dotweaver-workspaces"
RUNNER_IMAGE="dotweaver-runner"
# Token d'abonnement Claude Code (généré via `claude setup-token`). Ne JAMAIS committer la vraie valeur.
CLAUDE_CODE_OAUTH_TOKEN=""
